# Choose your LLM Provider
# Currently set up for OpenAI, but LiteLLM allows swapping to Ollama, Anthropic, etc.
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# Messaging
# Create a bot via BotFather on Telegram to get a token: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Call Handling 
# (For future expansion into SMS / Phone proxy)
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_auth
# TWILIO_PHONE_NUMBER=your_number
