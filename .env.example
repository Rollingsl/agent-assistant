# =============================================================================
#  OPAS — Environment Configuration
#  Copy this file to .env and fill in your values.
#  ⚠️  Never commit your .env file to version control.
# =============================================================================

# ── LLM / Inference Engine ────────────────────────────────────────────────────
# Required. Used by the OPAS core agent for all reasoning and generation.
# LiteLLM is used under the hood, so you can swap to any compatible provider.
# Examples: gpt-4o | gpt-4o-mini | claude-3-5-sonnet | ollama/llama3
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# ── Email / Gmail Operator ────────────────────────────────────────────────────
# Required for the email skill. Use a Gmail App Password (not your login password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=you@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram: https://t.me/botfather
# Get your chat ID by messaging @userinfobot after starting your bot.
TELEGRAM_TOKEN=123456:ABC-DEF_your_token_here
TELEGRAM_CHAT_ID=-100123456789

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps and install it to your workspace.
# Required scopes: channels:read, chat:write, channels:history
SLACK_TOKEN=xoxb-your-bot-oauth-token
SLACK_CHANNEL=#general
SLACK_WORKSPACE=your-workspace-name

# ── Discord ───────────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
# Enable: Message Content Intent, Server Members Intent
# Right-click any server/channel with Developer Mode ON to get IDs.
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=123456789012345678
DISCORD_CHANNEL_ID=123456789012345678

# ── Optional / Future ─────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_auth
# TWILIO_PHONE_NUMBER=+1234567890
